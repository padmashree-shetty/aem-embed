{
  "name": "@subway/eds-app",
  "private": true,
  "version": "1.0.0",
  "description": "Subway Digital E-commerce - Edge Delivery Services",
  "type": "module",
  "scripts": {
    "postinstall": "node ../../scripts/setup-git-symlink.js",
    "dev": "concurrently -k -n aem,css -c magenta,cyan \"npm run dev:aem\" \"npm run dev:css\"",
    "dev:aem": "aem up --url https://main--digital-ecomm-eds--Subway-Technology.aem.page",
    "dev:css": "tailwindcss -i src/tailwind-input.css -o styles/tailwind.css --watch --postcss",
    "build": "npm run build:json && npm run build:css",
    "build:css": "tailwindcss -i src/tailwind-input.css -o styles/tailwind.css --postcss --minify",
    "build:json": "npm-run-all -p build:json:models build:json:definitions build:json:filters",
    "build:json:models": "merge-json-cli -i \"models/_component-models.json\" -o \"component-models.json\"",
    "build:json:definitions": "merge-json-cli -i \"models/_component-definition.json\" -o \"component-definition.json\"",
    "build:json:filters": "merge-json-cli -i \"models/_component-filters.json\" -o \"component-filters.json\"",
    "sync-fonts": "cp ../../packages/shared-styles/src/fonts/*.woff2 fonts/",
    "clean": "rm -rf styles/tailwind.css",
    "lint:js": "eslint . --ext .json,.js,.mjs",
    "lint:css": "stylelint \"blocks/**/*.css\" \"styles/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Subway-Technology/digital-ecomm-web.git"
  },
  "author": "Subway Technology",
  "license": "UNLICENSED",
  "dependencies": {
    "@subway/shared-styles": "workspace:*"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.28.6",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-json": "3.1.0",
    "eslint-plugin-xwalk": "github:adobe-rnd/eslint-plugin-xwalk",
    "merge-json-cli": "1.0.4",
    "npm-run-all": "4.1.5",
    "postcss": "^8.4.49",
    "postcss-import": "^16.1.1",
    "stylelint": "17.0.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "^3.4.19"
  }
}
